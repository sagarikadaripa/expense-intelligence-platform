<div class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">AI Insights</h1>
  <p class="text-slate-500 text-sm mt-1">Spending patterns, budget alerts, and recommendations</p>
</div>

<% if @insights.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% @insights.each do |insight| %>
      <div class="p-5 rounded-xl border border-slate-200 <%= insight.severity == 'critical' ? 'bg-red-50 border-red-200' : insight.severity == 'warning' ? 'bg-amber-50 border-amber-200' : 'bg-blue-50 border-blue-200' %>">
        <p class="text-sm font-semibold text-slate-800"><%= insight.title %></p>
        <p class="text-sm text-slate-600 mt-2"><%= insight.body %></p>
        <p class="text-xs text-slate-400 mt-3"><%= insight.created_at.strftime("%d %b %Y") %></p>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-xl border border-slate-200 p-12 text-center">
    <p class="text-slate-400 text-sm">Insights will appear once you import transactions.</p>
    <%= link_to "Import transactions", dashboard_path(tab: "import"), class: "inline-block mt-4 text-indigo-600 text-sm hover:underline" %>
  </div>
<% end %>

<% recommendations = @dashboard[:recommendations] || [] %>
<% if recommendations.any? %>
  <div class="mt-8">
    <h2 class="font-semibold text-slate-800 mb-4">Recommendations</h2>
    <div class="space-y-3">
      <% recommendations.each do |rec| %>
        <div class="bg-white rounded-lg border border-slate-200 p-4 text-sm text-slate-700">
          <%= rec[:message] || rec["message"] %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
