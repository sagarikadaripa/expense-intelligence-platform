<% content_for :title, "Sign Up — Expense Intelligence" %>

<div class="min-h-screen bg-slate-50 flex items-center justify-center px-4">
  <div class="w-full max-w-lg bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
    <div class="text-center mb-8">
      <div class="w-12 h-12 bg-indigo-600 rounded-xl flex items-center justify-center text-white font-bold mx-auto mb-3">EI</div>
      <h1 class="text-2xl font-bold text-slate-900">Get started</h1>
      <p class="text-slate-500 text-sm mt-1">Track expenses via CSV import or WhatsApp.</p>
    </div>

    <%= form_with model: @user, url: signup_path, class: "space-y-4" do |f| %>
      <% if @user&.errors&.any? %>
        <div class="p-3 bg-red-50 text-red-700 rounded-lg text-sm">
          <%= @user.errors.full_messages.join(", ") %>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">
          <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :name, required: true, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" %>
        </div>
        <div class="col-span-2">
          <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.email_field :email, required: true, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" %>
        </div>
        <div>
          <%= f.label :mobile_number, "Mobile", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.telephone_field :mobile_number, required: true, placeholder: "+91...", class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" %>
        </div>
        <div>
          <%= f.label :whatsapp_number, "WhatsApp", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.telephone_field :whatsapp_number, required: true, placeholder: "+91...", class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:outline-none" %>
        </div>
        <div class="col-span-2">
          <%= f.label :preferred_currency, "Currency", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.select :preferred_currency, %w[INR USD EUR GBP], {}, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
        </div>
        <div class="col-span-2">
          <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.password_field :password, required: true, minlength: 8, class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
        </div>
      </div>

      <%= f.submit "Create Account", class: "w-full bg-indigo-600 text-white py-2.5 rounded-lg font-medium hover:bg-indigo-700 cursor-pointer" %>
    <% end %>

    <p class="text-center text-sm text-slate-500 mt-6">
      Already have an account? <%= link_to "Sign in", login_path, class: "text-indigo-600 hover:underline" %>
    </p>
  </div>
</div>
